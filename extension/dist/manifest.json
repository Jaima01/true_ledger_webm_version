{
  "manifest_version": 3,
  "name": "VERI-Real Trust Indicator",
  "description": "Detect synthetic media and display trust badges backed by AI + blockchain evidence.",
  "version": "0.1.0",
  "action": {
    "default_title": "VERI-Real",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:8000/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/main.ts-Bl13ekto.js"
      ],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://m.youtube.com/*",
        "https://twitter.com/*",
        "https://www.youtube.com/*",
        "https://x.com/*",
        "https://youtube.com/*"
      ],
      "resources": [
        "icons/icon6.png",
        "assets/main.ts-Bl13ekto.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
