# Supabase Postgres
DATABASE_URL=postgresql+asyncpg://postgres:YOUR-PASSWORD@db.xxxx.supabase.co:5432/postgres

# Redis (overridden in docker-compose)
REDIS_URL=redis://localhost:6379/0

# Agent service URL
AGENT_BASE_URL=http://localhost:8002

# Gemini API key (only needed if running agent locally without docker)
GEMINI_API_KEY=your-gemini-api-key

# App settings
API_TITLE=Deepfake Detection Backend
DEBUG=false

# Chunk queue management
CHUNK_TEMP_DIR=/tmp/true-ledger/chunks
CHUNK_QUEUE_TTL_SECONDS=3600
CHUNK_INACTIVITY_TIMEOUT_SECONDS=6
