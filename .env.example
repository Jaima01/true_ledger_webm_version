# Supabase Postgres (shared by orchestrator + backend)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR-PASSWORD@db.xxxx.supabase.co:5432/postgres

# Redis (overridden inside docker-compose, set this for local non-docker runs)
REDIS_URL=redis://localhost:6379/0

# Gemini AI key (used by the agent service)
GEMINI_API_KEY=your-gemini-api-key

# Service URLs (used when running outside docker-compose)
BACKEND_BASE_URL=http://localhost:8001
ORCHESTRATOR_BASE_URL=http://localhost:8000
AGENT_BASE_URL=http://localhost:8002

# App settings
API_TITLE=Deepfake Detection Platform
DEBUG=false

# Chunk queue management (backend)
CHUNK_TEMP_DIR=/tmp/true-ledger/chunks
CHUNK_QUEUE_TTL_SECONDS=3600
CHUNK_INACTIVITY_TIMEOUT_SECONDS=6
